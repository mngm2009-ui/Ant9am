<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>حاسبة الأختام الشاملة - سيرفر 92</title>
    <style>
        :root { --gold: #ffd700; --orange-p: #ff8c00; --orange: #ffa500; --bg: #121212; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: var(--bg); color: #e0e0e0; padding: 15px; min-height: 100vh; position: relative; padding-bottom: 50px; }
        .container { max-width: 950px; margin: auto; background: #1e1e1e; padding: 25px; border-radius: 20px; border: 1px solid #333; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .header-section { text-align: center; margin-bottom: 30px; }
        h1 { color: var(--gold); text-shadow: 2px 2px 4px rgba(0,0,0,0.5); margin-bottom: 5px; }
        .credit { font-size: 0.9rem; color: #bbb; font-style: italic; }
        .grid-header { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 10px; padding: 10px; font-weight: bold; background: #333; border-radius: 8px; margin-bottom: 10px; text-align: center; }
        .seal-row { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 10px; background: #252525; padding: 12px; margin-bottom: 8px; border-radius: 8px; align-items: center; transition: 0.2s; border: 1px solid transparent; }
        .seal-row:hover { border-color: var(--gold); background: #2d2d2d; }
        select { width: 100%; padding: 10px; border-radius: 5px; background: #333; color: white; border: 1px solid #555; cursor: pointer; }
        .target-section { display: flex; justify-content: space-around; background: #2d2d2d; padding: 20px; border-radius: 15px; margin-bottom: 25px; border: 2px solid var(--gold); }
        .target-item label { display: block; font-weight: bold; margin-bottom: 8px; text-align: center; }
        .btn { width: 100%; background: var(--gold); color: #000; padding: 18px; border: none; border-radius: 12px; font-weight: bold; font-size: 1.3rem; cursor: pointer; margin-top: 20px; box-shadow: 0 4px 15px rgba(255,215,0,0.3); }
        .results { margin-top: 25px; padding: 25px; background: #000; border-radius: 15px; display: none; border-right: 8px solid var(--gold); }
        .fire { color: #ff4500; } .water { color: #1e90ff; } .success { color: #32cd32; font-weight: bold; }
        .cost { color: #32cd32; font-size: 1.5rem; font-weight: bold; }
        .info-tag { font-size: 0.8rem; display: block; color: #aaa; margin-top: 4px; }
        .footer-signature { position: absolute; bottom: 10px; left: 15px; font-size: 0.65rem; color: #444; direction: ltr; }
    </style>
</head>
<body>

<div class="container">
    <div class="header-section">
        <h1>🦅 الحاسبة الشاملة لأختام النسر (12 ختم)</h1>
        <div class="credit">تم البرمجة خاص لسيرفر 92 مع الحب ❤️</div>
    </div>

    <div class="target-section">
        <div class="target-item">
            <label class="fire">هدف تفعيل النار:</label>
            <select id="target-fire">
                <option value="0">0</option>
                <option value="4">Level 1 (4)</option>
                <option value="8">Level 2 (8)</option>
                <option value="12" selected>Level 3 (12)</option>
            </select>
        </div>
        <div class="target-item">
            <label class="water">هدف تفعيل الماء:</label>
            <select id="target-water">
                <option value="0">0</option>
                <option value="4">Level 1 (4)</option>
                <option value="8">Level 2 (8)</option>
                <option value="12" selected>Level 3 (12)</option>
            </select>
        </div>
    </div>

    <div class="grid-header">
        <div>اسم الختم ونوعه</div>
        <div>المستوى الحالي</div>
        <div>تحويل لفل 50</div>
    </div>

    <div id="seals-list"></div>

    <button class="btn" onclick="calculate()">تحليل النقاط وحساب التكاليف 💰</button>

    <div id="result-box" class="results">
        <h2 style="margin-top:0; color:var(--gold);">📋 تقريرك الضريبي والفني:</h2>
        <p id="total-points" style="font-size: 1.3rem;"></p>
        <div id="status-report"></div>
        <hr style="border: 0.5px solid #333; margin: 20px 0;">
        <div class="cost" id="total-cost"></div>
        <p style="font-size: 0.9rem; color: #888;">* ملاحظة: الحسبة مبنية على عدد القطع وسعر الفئة (ذهبي 50$، برتقالي+ 30$، برتقالي 20$).</p>
    </div>
</div>

<div class="footer-signature">برمجة وتنفيذ الشيخ اعدام 92</div>

<script>
    const sealsArr = [
        // الفئة الذهبية (50$)
        { name: "الفيل", type: "gold", pattern: {10:'fire', 20:'water', 30:'fire', 40:'earth', 50:'mystery'} },
        { name: "حورس", type: "gold", pattern: {10:'fire', 20:'water', 30:'fire', 40:'earth', 50:'mystery'} },
        { name: "الفينيق", type: "gold", pattern: {10:'fire', 20:'earth', 30:'fire', 40:'water', 50:'mystery'} },
        
        // الفئة البرتقالية بلس (30$)
        { name: "الجمل", type: "orange_p", pattern: {10:'earth', 20:'fire', 30:'water', 40:'fire', 50:'mystery'} },
        
        // الفئة البرتقالية العادية (20$) - تم تعديل الصقر والواوي هنا
        { name: "الصقر", type: "orange", pattern: {10:'water', 20:'fire', 30:'earth', 40:'fire', 50:'mystery'} },
        { name: "الواوي", type: "orange", pattern: {10:'water', 20:'fire', 30:'earth', 40:'fire', 50:'mystery'} },
        { name: "الدلفين", type: "orange", pattern: {10:'water', 20:'water', 30:'water', 40:'fire', 50:'water'} },
        { name: "القرش", type: "orange", pattern: {10:'water', 20:'water', 30:'water', 40:'fire', 50:'water'} },
        { name: "فرس البحر", type: "orange", pattern: {10:'water', 20:'water', 30:'water', 40:'fire', 50:'water'} },
        { name: "الحلزون", type: "orange", pattern: {10:'water', 20:'water', 30:'water', 40:'fire', 50:'water'} },
        { name: "الحوت", type: "orange", pattern: {10:'water', 20:'water', 30:'water', 40:'fire', 50:'water'} },
        { name: "السلحفاة", type: "orange", pattern: {10:'water', 20:'water', 30:'water', 40:'fire', 50:'water'} }
    ];

    const levels = [0, 10, 20, 25, 30, 35, 40, 45, 50];
    const piecesMap = { 0:0, 10:1, 20:2, 25:5, 30:10, 35:18, 40:29, 45:43, 50:61 };
    const priceMap = { gold: 50, orange_p: 30, orange: 20 };

    function init() {
        const list = document.getElementById('seals-list');
        sealsArr.forEach((seal, idx) => {
            let lvlOptions = levels.map(l => `<option value="${l}">${l}</option>`).join('');
            let colorLabel = seal.type === 'gold' ? 'ذهبي ($50)' : (seal.type === 'orange_p' ? 'برتقالي+ ($30)' : 'برتقالي ($20)');
            list.innerHTML += `
                <div class="seal-row">
                    <div>
                        <strong>${seal.name}</strong>
                        <span class="info-tag">${colorLabel}</span>
                    </div>
                    <select id="lvl-${idx}">${lvlOptions}</select>
                    <select id="conv-${idx}">
                        <option value="fire">نار 🔥</option>
                        <option value="water">ماء 💧</option>
                    </select>
                </div>`;
        });
    }

    function calculate() {
        let fPoints = 0, wPoints = 0, totalCost = 0;
        const tFire = parseInt(document.getElementById('target-fire').value);
        const tWater = parseInt(document.getElementById('target-water').value);

        sealsArr.forEach((seal, idx) => {
            const currentLvl = parseInt(document.getElementById(`lvl-${idx}`).value);
            const conv = document.getElementById(`conv-${idx}`).value;

            [10, 20, 30, 40, 50].forEach(milestone => {
                if (currentLvl >= milestone) {
                    let element = seal.pattern[milestone];
                    if (element === 'mystery') element = conv;
                    if (element === 'fire') fPoints++;
                    if (element === 'water') wPoints++;
                }
            });

            totalCost += piecesMap[currentLvl] * priceMap[seal.type];
        });

        const resBox = document.getElementById('result-box');
        resBox.style.display = 'block';

        document.getElementById('total-points').innerHTML = 
            `النقاط الحالية: <span class="fire">🔥 نار ${fPoints}</span> | <span class="water">💧 ماء ${wPoints}</span>`;

        let status = "";
        if (fPoints >= tFire && tFire > 0) {
            status += `<p class="success">✅ ( تم تفعيل العنصر ) - النار مستوى ${Math.floor(tFire/4)}</p>`;
        } else if (tFire > 0) {
            status += `<p class="fire">⚠️ ينقصك ${tFire - fPoints} نقاط نار للهدف.</p>`;
        }

        if (wPoints >= tWater && tWater > 0) {
            status += `<p class="success">✅ ( تم تفعيل العنصر ) - الماء مستوى ${Math.floor(tWater/4)}</p>`;
        } else if (tWater > 0) {
            status += `<p class="water">⚠️ ينقصك ${tWater - wPoints} نقاط ماء للهدف.</p>`;
        }
        
        document.getElementById('status-report').innerHTML = status;
        document.getElementById('total-cost').innerHTML = `إجمالي تكلفة التطوير: $${totalCost.toLocaleString()}`;
        
        resBox.scrollIntoView({ behavior: 'smooth' });
    }

    init();
</script>

</body>
</html>
